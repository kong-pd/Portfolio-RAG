# AI Providers — at least one chat provider API key is required.
# Chat fallback order is configured in application.yml (app.ai.chat.providers).
# Groq (free, fast): https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# OpenAI (chat fallback + default embeddings, 1536-dim): https://platform.openai.com
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini (optional chat fallback / 768-dim embeddings): https://aistudio.google.com
GOOGLE_API_KEY=your_google_api_key_here

# DB / JWT
POSTGRES_USER=raguser
POSTGRES_PASSWORD=changeme
POSTGRES_DB=ragdb
JWT_SECRET=change-this-to-a-256-bit-secret-in-production
